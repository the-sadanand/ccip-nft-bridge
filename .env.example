# =============================================================================
# CCIP NFT Bridge - Environment Variables Template
# Copy this file to `.env` and fill in real values. Never commit your real .env.
# =============================================================================

# ---- Wallet -----------------------------------------------------------------
# Private key of the account used to deploy contracts and send transactions.
# Must hold testnet AVAX (Fuji), testnet ETH (Arbitrum Sepolia), and LINK on both.
# Do NOT prefix with 0x is fine either way (ethers.js accepts both).
PRIVATE_KEY=0xyourprivatekeyhere

# ---- RPC Endpoints ------------------------------------------------------------
# Get free RPC URLs from Alchemy, Infura, Ankr, or the public endpoints below.
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ---- Chainlink CCIP Router Addresses ------------------------------------------
# See https://docs.chain.link/ccip/supported-networks/v1_2_0/testnet
CCIP_ROUTER_FUJI=0xF694E193200268f9a4868e4Aa017A0118C9a8177
CCIP_ROUTER_ARBITRUM_SEPOLIA=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165

# ---- LINK Token Addresses -------------------------------------------------------
LINK_TOKEN_FUJI=0x0b9d5D9136855f6FEc3c0993feE6E9CE8a297846
LINK_TOKEN_ARBITRUM_SEPOLIA=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E

# ---- CCIP Chain Selectors (optional overrides; sensible defaults are built in) --
CCIP_CHAIN_SELECTOR_FUJI=14767482510784806043
CCIP_CHAIN_SELECTOR_ARBITRUM_SEPOLIA=3478487238524512106

# ---- Block Explorer API Keys (optional, used for `forge verify-contract`) ------
SNOWTRACE_API_KEY=
ARBISCAN_API_KEY=
